# === Submission Bot Identity ===
SUBMIT_PRIVATE_KEY=0x...
# Or use Foundry keystore:
# SUBMIT_KEYSTORE_ACCOUNT=submit-bot
# SUBMIT_KEYSTORE_PASSWORD=

# === Rating Bot Identity ===
RATE_PRIVATE_KEY=0x...
# Or use Foundry keystore:
# RATE_KEYSTORE_ACCOUNT=rate-bot
# RATE_KEYSTORE_PASSWORD=

# Network (required)
RPC_URL=
CHAIN_ID=

# Contracts (optional for supported chains; auto-derived from @curyo/contracts when omitted)
CREP_TOKEN_ADDRESS=
CONTENT_REGISTRY_ADDRESS=
VOTING_ENGINE_ADDRESS=
VOTER_ID_NFT_ADDRESS=
CATEGORY_REGISTRY_ADDRESS=

# Ponder indexer (required)
PONDER_URL=

# Optional external APIs (unlock additional content sources + rating strategies)
TMDB_API_KEY=
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
RAWG_API_KEY=
GITHUB_TOKEN=

# Voting config (rating bot)
VOTE_STAKE=1000000
VOTE_THRESHOLD=5.0
RATE_FRONTEND_ADDRESS=

# Limits
MAX_VOTES_PER_RUN=10
MAX_SUBMISSIONS_PER_RUN=5
MAX_SUBMISSIONS_PER_CATEGORY=3
