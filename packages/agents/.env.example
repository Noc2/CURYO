# Hosted Curyo origin used by SDK HTTP and MCP flows.
CURYO_API_BASE_URL=https://curyo.example

# Optional managed agent bearer token. Configure scopes and budget caps in the app.
CURYO_MCP_TOKEN=

# Optional MCP endpoint override. SDK clients default to ${CURYO_API_BASE_URL}/api/mcp.
CURYO_MCP_API_URL=

# Optional MCP protocol version override.
CURYO_MCP_PROTOCOL_VERSION=
