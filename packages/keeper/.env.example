# Network (required)
RPC_URL=
CHAIN_ID=

# Contracts (optional only for unsupported chains)
# Supported chains read the latest deployment from @curyo/contracts.
VOTING_ENGINE_ADDRESS=
CONTENT_REGISTRY_ADDRESS=
ROUND_REWARD_DISTRIBUTOR_ADDRESS=
FRONTEND_REGISTRY_ADDRESS=

# Wallet (Foundry keystore — preferred)
KEYSTORE_ACCOUNT=keeper
KEYSTORE_PASSWORD=

# Alternatively, raw private key (not recommended)
# KEEPER_PRIVATE_KEY=0x...

# Keeper behavior
KEEPER_INTERVAL_MS=30000
KEEPER_STARTUP_JITTER_MS=0
KEEPER_CLEANUP_BATCH_SIZE=25

# Monitoring
METRICS_ENABLED=true
METRICS_BIND_ADDRESS=127.0.0.1
METRICS_PORT=9090

# Logging ("json" for production, "text" for development)
LOG_FORMAT=json

# Tuning (optional)
# CHAIN_NAME=Celo
# DORMANCY_PERIOD=2592000
# MIN_GAS_BALANCE_WEI=10000000000000000
# MAX_GAS_PER_TX=2000000

# Hosted MCP frontend-fee ops (optional)
# KEEPER_FRONTEND_FEE_ENABLED=true
# KEEPER_FRONTEND_ADDRESS=
# KEEPER_FRONTEND_FEE_LOOKBACK_ROUNDS=8
# KEEPER_FRONTEND_FEE_WITHDRAW=true
