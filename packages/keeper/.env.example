# Network
RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CHAIN_ID=11142220

# Contracts (required — addresses depend on deployment)
VOTING_ENGINE_ADDRESS=0xee0D38c80487a33883Ef14b7DdAAE3E21228Fc9F
CONTENT_REGISTRY_ADDRESS=0xD34Da20bEb6Ea00Be52822a22248Fed2E555b1b3

# Wallet (Foundry keystore — preferred)
KEYSTORE_ACCOUNT=keeper
KEYSTORE_PASSWORD=

# Alternatively, raw private key (not recommended)
# KEEPER_PRIVATE_KEY=0x...

# Keeper behavior
KEEPER_INTERVAL_MS=30000
KEEPER_STARTUP_JITTER_MS=0

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090

# Logging ("json" for production, "text" for development)
LOG_FORMAT=json

# Tuning (optional)
# CHAIN_NAME=Celo Sepolia
# DORMANCY_PERIOD=2592000
