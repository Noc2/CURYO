{
  "name": "@curyo/nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true yarn build",
    "build": "rm -rf .next && next build",
    "check-types": "next typegen && tsc --noEmit --incremental",
    "dev": "next dev",
    "format": "prettier --write . '!(node_modules|.next|contracts)/**/*'",
    "ipfs": "NEXT_PUBLIC_IPFS_BUILD=true yarn build && yarn bgipfs upload config init -u https://upload.bgipfs.com && CID=$(yarn bgipfs upload out | grep -o 'CID: [^ ]*' | cut -d' ' -f2) && [ ! -z \"$CID\" ] && echo '🚀 Upload complete! Your site is now available at: https://community.bgipfs.com/ipfs/'$CID || echo '❌ Upload failed'",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --ignore-pattern public --ignore-pattern .next --ignore-pattern out --ignore-pattern contracts",
    "serve": "next start",
    "start": "next dev",
    "vercel": "vercel --build-env YARN_ENABLE_IMMUTABLE_INSTALLS=false --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "vercel:yolo": "vercel --build-env YARN_ENABLE_IMMUTABLE_INSTALLS=false --build-env ENABLE_EXPERIMENTAL_COREPACK=1 --build-env NEXT_PUBLIC_IGNORE_BUILD_ERROR=true --build-env VERCEL_TELEMETRY_DISABLED=1",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "node ../../scripts/run-node-tests.mjs hooks lib utils",
    "whitepaper": "tsx scripts/whitepaper/generate.tsx",
    "e2e": "playwright test --config e2e/playwright.config.ts --project=chromium",
    "e2e:ci:lifecycle": "playwright test --config e2e/playwright.config.ts --project=chromium --project=settlement --project=round-cancellation --project=content-dormancy",
    "e2e:ci:keeper": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=settlement-keeper",
    "e2e:settlement": "playwright test --config e2e/playwright.config.ts --project=settlement",
    "e2e:settlement:keeper": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=settlement-keeper",
    "e2e:mobile": "playwright test --config e2e/playwright.config.ts --project=mobile-phone --project=mobile-tablet",
    "e2e:full": "REQUIRE_E2E_KEEPER=1 playwright test --config e2e/playwright.config.ts --project=chromium --project=settlement --project=settlement-keeper --project=round-cancellation --project=content-dormancy --project=mobile-phone --project=mobile-tablet",
    "e2e:firefox": "playwright test --config e2e/playwright.config.ts --project=firefox",
    "e2e:webkit": "playwright test --config e2e/playwright.config.ts --project=webkit",
    "e2e:all-browsers": "playwright test --config e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:reset": "bash e2e/scripts/reset-chain.sh"
  },
  "dependencies": {
    "@curyo/contracts": "workspace:*",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "@heroicons/react": "~2.1.5",
    "@libsql/client": "^0.17.0",
    "@scaffold-ui/components": "0.1.9",
    "@scaffold-ui/hooks": "0.1.7",
    "@selfxyz/core": "1.2.0-beta.1",
    "@selfxyz/qrcode": "^1.0.18",
    "@tanstack/react-query": "~5.59.15",
    "@thirdweb-dev/wagmi-adapter": "0.2.208",
    "blo": "~1.2.0",
    "daisyui": "5.0.9",
    "drizzle-orm": "~0.45.1",
    "framer-motion": "^12.29.2",
    "gsap": "^3.14.2",
    "next": "~15.5.12",
    "next-nprogress-bar": "~2.3.13",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "react-hot-toast": "~2.4.0",
    "react-lite-youtube-embed": "^3.3.3",
    "react-tweet": "^3.3.0",
    "server-only": "0.0.1",
    "thirdweb": "5.119.1",
    "tlock-js": "^0.9.0",
    "usehooks-ts": "~3.1.0",
    "viem": "2.39.0",
    "wagmi": "2.19.5",
    "zustand": "~5.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/postcss": "4.0.15",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/node": "^20.10.7",
    "@types/react": "~19.0.7",
    "@xmldom/xmldom": "^0.8.11",
    "abitype": "1.0.6",
    "autoprefixer": "~10.4.20",
    "bgipfs": "~0.0.12",
    "drizzle-kit": "^0.31.8",
    "eslint": "~9.23.0",
    "eslint-config-next": "~15.5.12",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-prettier": "~5.2.4",
    "mathjax-full": "^3.2.2",
    "postcss": "~8.4.45",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "tsx": "^4.21.0",
    "type-fest": "~4.26.1",
    "typescript": "~5.8.2",
    "vercel": "~39.1.3"
  },
  "license": "MIT",
  "packageManager": "yarn@3.2.3",
  "engines": {
    "node": ">=20.18.3 <21"
  }
}
