# Template for NextJS environment variables.
# Copy this file to .env.local and fill in the values.
# When deploying, store these in Vercel/system env config.

# RPC provider (get your own at https://dashboard.alchemyapi.io)
# If not set, a shared default key is used (not recommended for production)
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# TMDB API (https://www.themoviedb.org/settings/api) — required for Movies category
NEXT_PUBLIC_TMDB_API_KEY=

# RAWG API (https://rawg.io/apidocs) — required for Games category
RAWG_API_KEY=

# Database (SQLite for local, Turso for production)
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# Foundry keystore — shared wallet for Keeper + Faucet (server-only)
# Name of keystore file in ~/.foundry/keystores/
KEYSTORE_ACCOUNT=
# Password to decrypt the keystore (leave empty to use raw private key fallbacks below)
KEYSTORE_PASSWORD=

# Fallback: raw private keys (used when KEYSTORE_ACCOUNT/PASSWORD are not set)
FAUCET_PRIVATE_KEY=
KEEPER_PRIVATE_KEY=

# Dev-mode faucet — mints cREP and Voter ID without passport verification
# NEXT_PUBLIC_DEV_FAUCET controls UI visibility; DEV_FAUCET_ENABLED gates the server API
NEXT_PUBLIC_DEV_FAUCET=true
DEV_FAUCET_ENABLED=true

# tlock encryption mock ("true" for local Anvil dev, unset or "false" for production)
NEXT_PUBLIC_TLOCK_MOCK=true

# Ponder Indexer URL (run `yarn ponder:dev` to start locally)
NEXT_PUBLIC_PONDER_URL=http://localhost:42069

# Frontend operator address for fee distribution (optional)
# NEXT_PUBLIC_FRONTEND_CODE=0x...

# Build flags (optional)
# NEXT_PUBLIC_IGNORE_BUILD_ERROR=true
# NEXT_PUBLIC_IPFS_BUILD=true
