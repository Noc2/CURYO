{
  "name": "@curyo/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Official read-only Curyo MCP server",
  "homepage": "https://github.com/Noc2/CURYO/tree/main/packages/mcp-server",
  "repository": {
    "type": "git",
    "url": "git@github.com:Noc2/CURYO.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/Noc2/CURYO/issues"
  },
  "keywords": [
    "curyo",
    "mcp",
    "model-context-protocol",
    "trust",
    "reputation"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "start:http": "CURYO_MCP_TRANSPORT=streamable-http tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "dev:http": "CURYO_MCP_TRANSPORT=streamable-http tsx watch src/index.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  }
}
