# Start blocks
PONDER_CONTENT_REGISTRY_START_BLOCK=0
PONDER_ROUND_VOTING_ENGINE_START_BLOCK=0
PONDER_ROUND_REWARD_DISTRIBUTOR_START_BLOCK=0
PONDER_CATEGORY_REGISTRY_START_BLOCK=0
PONDER_PROFILE_REGISTRY_START_BLOCK=0
PONDER_FRONTEND_REGISTRY_START_BLOCK=0
PONDER_VOTER_ID_NFT_START_BLOCK=0
PONDER_CREP_START_BLOCK=0

